    "pi-package",
    "pi-coding-agent",
    "pi-extension",
    "vision",
    "multimodal",
    "deepseek",
    "image",
    "pi"
  ],
  "license": "MIT",
  "author": "Oyaxira",
  "repository": {
    "type": "git",
    "url": "https://github.com/Oyaxira/pi-visionizer"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "check": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
